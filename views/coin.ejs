<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/home.css" />
    <link rel="stylesheet" href="/css/header.css" />
    <link rel="stylesheet" href="/css/about.css" />
    <link rel="stylesheet" href="/css/coin.css" />
    <link rel="stylesheet" href="/css/reset.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
      rel="stylesheet"
    />
    <title> <%=coin.name%> info</title>
  </head>
  <body>
    <div class="wrapper">

      <header class="header">
            <div class="container">
                <div class="header__flexbox">
                    <a href="/" class="header__logo-link">
                        <img class="logo" src="../img/barnbridge-bond-logo.svg" alt="ApexCrypto Logo" />
                        <span class="logo__text">ApexCrypto</span>
                    </a>
                    <nav class="header__nav">
                        <a class="nav__item" href="/">Home</a>
                        <a class="nav__item nav__item--active" href="/about">About Project</a>
                        <a class="nav__item" href="/login">Login</a>
                        <a class="nav__item nav__item--btn" href="/register">Sign Up</a>
                    </nav>
                    <div class="header__profile">
                        <img class="profile__logo" src="../img/profile-svgrepo-com.svg" alt="Profile" />
                    </div>
                </div>
            </div>
        </header>

      <main class="main">
        <div class="container__tradingview ">
          <div class="tradingview__flexbox">
            <div class="tdflexbox__container"></div>
            
            <!-- TradingView Widget BEGIN -->
            <div
              class="tradingview-widget-container"
              style="height: 100%; width: 100%"
            >
              <div
                class="tradingview-widget-container__widget"
                style="height: calc(100% - 32px); width: 100%"
              ></div>
              <script
                type="text/javascript"
                src="https://s3.tradingview.com/external-embedding/embed-widget-advanced-chart.js"
                async
              >
                  {
                  "allow_symbol_change": true,
                  "calendar": false,
                  "details": false,
                  "hide_side_toolbar": true,
                  "hide_top_toolbar": false,
                  "hide_legend": false,
                  "hide_volume": false,
                  "hotlist": false,
                  "interval": "D",
                  "locale": "en",
                  "save_image": true,
                  "style": "1",
                  "symbol": "<%= coin.symbol %>USDT",
                  "theme": "dark",
                  "timezone": "Etc/UTC",
                  "backgroundColor": "#0F0F0F",
                  "gridColor": "rgba(242, 242, 242, 0.06)",
                  "watchlist": [],
                  "withdateranges": false,
                  "compareSymbols": [],
                  "studies": [],
                  "autosize": true
                }
              </script>
            </div>
            <!-- TradingView Widget END -->

          </div>
          <div class="coinInfo__flexbox">
            <div class="description__container">
              <h1 class="description__title">About <%=coin.name%>:</h1>
              <p class="description__text"><%=coin.description%></p>
              <div class="links__container">
                <a class="links__link" href="<%=coin.website_link%>">
                  WebSite <img class="website_link_logo" src="/img/external-link.png" alt="website_link_logo">
                </a>
                <a class="links__link" href="<%=coin.twitter_link%>">
                  Twitter <img class="website_link_logo" src="/img/twitter.png" alt="twitter_link_logo">
                </a>
                <a class="links__link" href="<%=coin.facebook_link%>">
                  Facebook <img class="website_link_logo" src="/img/facebook.png" alt="website_link_logo">
                </a>
                <a class="links__link" href="<%=coin.reddit_link%>">
                  Reddit <img class="website_link_logo" src="/img/reddit.png" alt="website_link_logo">
                </a>
                <a class="links__link" href="<%=coin.code_link%>">
                  Code <img class="website_link_logo" src="/img/code.png" alt="website_link_logo">
                </a>
              </div>
            </div>
            <div class="owerview__container">
              <h1 class="owerview__title">Owerview:</h1>
              <ul class="owerview__list">
                <li class="owerview__item" id="price__item">Loading...</li>
                <li class="owerview__item">Market cap: <%=coin.market_cap%></li>
                <li class="owerview__item">24h volume: <%=coin.h_volume%></li>
                <li class="owerview__item">1w low: <%=coin.w_low%></li>
                <li class="owerview__item">1w high: <%=coin.w_high%></li>
                <li class="owerview__item">Circulating supply: --</li>
              </ul>
            </div>
          </div>
        </div>
      </main>

      <footer class="footer">
            <div class="container">
                <div class="footer__grid">
                    <div class="footer__col footer__col--brand">
                        <div class="header__logo-link">
                            <img class="logo" src="../img/barnbridge-bond-logo.svg" alt="ApexCrypto Logo" />
                            <span class="logo__text">ApexCrypto</span>
                        </div>
                        <p class="footer__text">
                            An experimental cryptocurrency tracker built to master Full-Stack development and real-time WebSocket communication ecosystems.
                        </p>
                    </div>
                    <div class="footer__col">
                        <h4 class="footer__title">Navigation</h4>
                        <ul class="footer__links">
                            <li><a href="/">Home</a></li>
                            <li><a href="/about">About Project</a></li>
                            <li><a href="/login">Login</a></li>
                            <li><a href="/register">Sign Up</a></li>
                        </ul>
                    </div>
                    <div class="footer__col">
                        <h4 class="footer__title">Source Code</h4>
                        <ul class="footer__links">
                            <li><a href="https://github.com/igorkolesnikov2323-tech/Crypto-Express-" target="_blank">Project GitHub</a></li>
                            <li><a href="https://github.com/igorkolesnikov2323-tech" target="_blank">My Profile</a></li>
                            <li><a href="https://t.me/kolesnikoov17" target="_blank">Contact via Telegram</a></li>
                        </ul>
                    </div>
                </div>
                <div class="footer__bottom">
                    <p class="footer__copy">© 2026 ApexCrypto. Created for educational purposes.</p>
                    <p class="footer__disclaimer">
                        Disclaimer: This website is a demonstration educational project. All data, prices, and charts are fetched from open testing environments and do not constitute financial advice or investment recommendations.
                    </p>
                </div>
            </div>
        </footer>
    </div>
    <script>
      const coinSymbol = '<%= coin.symbol %>'.trim().toLowerCase()
      const priceItem = document.getElementById('price__item')
      function main(){
        const binanceWs = new WebSocket(`wss://stream.binance.com:9443/ws/${coinSymbol}usdt@miniTicker`)

      binanceWs.onopen = () => {
        console.log('Binance WebSocket Open...')
      }

      binanceWs.onmessage = (event) => {
        const data = JSON.parse(event.data)
        const price = Number(data.c).toFixed(2)
        priceItem.innerText = `Price: $${price}`
      }

      binanceWs.onerror = (error)=>{
        console.log('Binance WebSocket Error: ', error.message)
      }

      binanceWs.onclose = (event)=>{
        console.log('Binance WebSocket Connection closed: ', event.reason)
        console.log('retry after 5 sec...')
        setTimeout(() => {
          main()
        }, 5000);
      }
      }
      main()
    </script>
  </body>
</html>
